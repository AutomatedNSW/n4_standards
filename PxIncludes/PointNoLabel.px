<?xml version="1.0" encoding="UTF-8"?>
<!-- Niagara Presentation XML -->
<px version="1.0" media="workbench:WbPxMedia">
<import>
  <module name="baja"/>
  <module name="bajaui"/>
  <module name="converters"/>
  <module name="gx"/>
  <module name="kitPx"/>
</import>
<content>
<FlowPane align="center">

  <ResponsivePane forceNewRow="true">

    <BoundLabel name="content" font="bold 14.0pt Open Sans" foreground="#a5a5ba" halign="fill" valign="fill">
      <BoundLabelBinding ord="$(point)" statusEffect="color">
        <ObjectToString name="text" format="%out.value%"/>
      </BoundLabelBinding>
      <WsAnnotation name="wsAnnotation" value="2,2,8"/>
      <PopupBinding ord="$(point)|view:webChart:ChartWidget" title="History" modal="true"/>
    </BoundLabel>

  </ResponsivePane>

</FlowPane>
</content>
</px>
